{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(npx tsup:*)",
      "Bash(git commit:*)",
      "Bash(npx vitest:*)",
      "Bash(git add:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(git push:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "mcp__ide__getDiagnostics",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(AVER_ADAPTER=direct npx vitest run:*)",
      "Bash(npx tsx:*)",
      "Bash(npx playwright install:*)",
      "Bash(npx vite build:*)",
      "Bash(git checkout:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/stop\" || echo '{}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "_voice-hooks__speak$",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/pre-speak\" || echo '{}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!.*_voice-hooks__)",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/post-tool\" || echo '{}'"
          }
        ]
      }
    ]
  }
}
