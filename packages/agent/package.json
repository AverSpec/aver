{
  "name": "@aver/agent",
  "version": "0.1.1",
  "description": "AI agent platform for domain-driven development with Aver (experimental)",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": [
    "testing",
    "aver",
    "agent",
    "ai-agent",
    "tdd"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./tui": {
      "import": {
        "types": "./dist/tui.d.ts",
        "default": "./dist/tui.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@aver/skills": "workspace:^",
    "@aver/workspace": "workspace:^",
    "@libsql/client": "^0.17.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0",
    "@aver/core": "workspace:^",
    "@types/react": ">=19.0.0",
    "ink": ">=6.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@aver/core": "workspace:^",
    "@inkjs/ui": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "ink-testing-library": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
