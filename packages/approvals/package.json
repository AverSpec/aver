{
  "name": "@aver/approvals",
  "version": "0.1.0",
  "description": "Approval testing for Aver",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/approvals"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": ["testing", "approval-testing", "snapshot-testing", "visual-regression", "aver"],
  "publishConfig": { "access": "public" },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@aver/core": "workspace:*"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "pngjs": "^7.0.0",
    "pixelmatch": "^5.3.0"
  },
  "devDependencies": {
    "@aver/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/pixelmatch": "^5.2.6"
  }
}
