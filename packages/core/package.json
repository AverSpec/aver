{
  "name": "@averspec/core",
  "version": "0.1.1",
  "description": "Domain-driven acceptance testing framework",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/averspec/aver.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/averspec/aver",
  "bugs": "https://github.com/averspec/aver/issues",
  "keywords": [
    "aver",
    "testing",
    "bdd",
    "acceptance-testing",
    "domain-driven",
    "tdd"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "aver": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./internals": {
      "import": {
        "types": "./dist/internals.d.ts",
        "default": "./dist/internals.js"
      },
      "require": {
        "types": "./dist/internals.d.cts",
        "default": "./dist/internals.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.ts",
        "default": "./dist/reporter.js"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    },
    "./scaffold": {
      "import": {
        "types": "./dist/scaffold.d.ts",
        "default": "./dist/scaffold.js"
      },
      "require": {
        "types": "./dist/scaffold.d.cts",
        "default": "./dist/scaffold.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@averspec/telemetry": "workspace:^",
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@averspec/telemetry": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@averspec/telemetry": "workspace:^",
    "@clack/prompts": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
