{
  "name": "@aver/core",
  "version": "0.1.0",
  "description": "Domain-driven acceptance testing framework",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": ["testing", "bdd", "acceptance-testing", "domain-driven", "tdd"],
  "publishConfig": { "access": "public" },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "aver": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.ts",
        "default": "./dist/reporter.js"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@aver/workspace": "workspace:*",
    "@clack/prompts": "^1.0.0"
  }
}
