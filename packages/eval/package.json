{
  "name": "@aver/eval",
  "version": "0.1.1",
  "description": "LLM-as-judge evaluation primitives for Aver — judge(), providers, and AgentEval domain",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run --config vitest.config.eval.ts",
    "eval:replay": "AVER_EVAL_MODE=replay vitest run --config vitest.config.eval.ts",
    "eval:live": "AVER_EVAL_MODE=live vitest run --config vitest.config.eval.ts"
  },
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/eval"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": [
    "testing",
    "evaluation",
    "llm",
    "aver",
    "llm-as-judge"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0",
    "@anthropic-ai/sdk": ">=0.30.0",
    "@aver/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@aver/agent": "workspace:*",
    "@aver/core": "workspace:*",
    "@libsql/client": "^0.17.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
