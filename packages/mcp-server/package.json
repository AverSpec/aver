{
  "name": "@aver/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Aver domain-driven acceptance testing",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": ["testing", "mcp", "model-context-protocol", "ai-testing", "aver"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18.0.0" },
  "bin": { "aver-mcp": "./dist/index.js" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@aver/workspace": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@aver/core": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@aver/core": "workspace:^"
  }
}
