{
  "name": "@aver/mutation-testing",
  "version": "0.1.1",
  "description": "Mutation testing for Aver — verify spec precision via implementation and adapter mutations",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/mutation-testing"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": ["testing", "mutation-testing", "aver", "spec-precision"],
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "@aver/core": ">=0.1.0",
    "@stryker-mutator/core": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@stryker-mutator/core": { "optional": true }
  },
  "devDependencies": {
    "@aver/core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
