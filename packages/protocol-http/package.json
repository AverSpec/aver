{
  "name": "@averspec/protocol-http",
  "version": "0.1.1",
  "description": "HTTP protocol for Aver acceptance testing",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/averspec/aver.git",
    "directory": "packages/protocol-http"
  },
  "homepage": "https://averspec.dev",
  "bugs": "https://github.com/averspec/aver/issues",
  "keywords": ["testing", "http", "api-testing", "acceptance-testing", "aver"],
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "engines": { "node": ">=22.0.0" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@averspec/core": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@averspec/core": "workspace:^"
  }
}
