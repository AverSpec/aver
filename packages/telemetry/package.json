{
  "name": "@averspec/telemetry",
  "version": "0.1.1",
  "description": "Behavioral contract export and production trace verification for Aver",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/averspec/aver.git",
    "directory": "packages/telemetry"
  },
  "homepage": "https://github.com/averspec/aver",
  "bugs": "https://github.com/averspec/aver/issues",
  "keywords": [
    "testing",
    "aver",
    "telemetry",
    "observability",
    "otel",
    "contracts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./vitest": {
      "import": {
        "types": "./dist/vitest.d.ts",
        "default": "./dist/vitest.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@averspec/core": "workspace:^",
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@averspec/core": "workspace:^",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
