{
  "name": "@aver/workspace",
  "version": "0.1.1",
  "description": "Scenario workspace engine for the Aver BDD framework",
  "type": "module",
  "license": "MIT",
  "author": "Nate Jackson",
  "repository": {
    "type": "git",
    "url": "https://github.com/njackson/aver.git",
    "directory": "packages/workspace"
  },
  "homepage": "https://github.com/njackson/aver",
  "bugs": "https://github.com/njackson/aver/issues",
  "keywords": [
    "testing",
    "aver",
    "workspace",
    "bdd",
    "scenarios"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@opentelemetry/api": "^1.9.0",
    "lexorank": "^1.0.5"
  },
  "devDependencies": {
    "@aver/core": "workspace:^",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
